# API base URL. Use "/api" to go through the Vite dev proxy (recommended for local dev).
# For a deployed frontend, set this to your backend URL, e.g. https://api.example.com/api
VITE_API_URL=/api
# Set to "true" to run on built-in mock data without a backend (demo/offline mode).
VITE_USE_MOCK=false

# Firebase is no longer used for auth (the app uses its own JWT backend).
# These are kept only if you re-enable Firebase elsewhere.
VITE_FIREBASE_API_KEY=DEMO_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=demo.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-project
VITE_FIREBASE_STORAGE_BUCKET=demo.appspot.com
VITE_FIREBASE_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000:web:000
