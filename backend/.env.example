# Server
PORT=8000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/career_mentor

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# CORS (frontend origin)
CLIENT_ORIGIN=http://localhost:3000

# AI provider (Gemini). Leave USE_MOCK_AI=true to run without a key.
USE_MOCK_AI=true
GEMINI_API_KEY=

# Cloudinary (resume/avatar uploads). Optional in mock mode.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
